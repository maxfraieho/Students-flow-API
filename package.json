{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "preinstall": "sh -c 'rm -f package-lock.json yarn.lock; case \"$npm_config_user_agent\" in pnpm/*) ;; *) echo \"Use pnpm instead\" >&2; exit 1 ;; esac'",
    "dev": "corepack pnpm --filter @workspace/mockup-sandbox run dev",
    "build": "bash ./scripts/build-web.sh",
    "build:dev": "bash ./scripts/build-web.sh",
    "typecheck:libs": "tsc --build",
    "typecheck": "tsc --build"
  },
  "private": true,
  "devDependencies": {
    "typescript": "~5.9.2",
    "prettier": "^3.8.1"
  }
}
