# Copy this file to .env and fill in real values.
# .env is git-ignored and must NEVER be committed.

# GitHub Personal Access Token — required for seed_demo_data() and broadcast push.
# Needs scopes: repo (read + write)
# Set this in Replit Secrets or export it in your shell before running seeds.
GITHUB_TOKEN=YOUR_GITHUB_TOKEN_HERE

# FastAPI / Uvicorn
# HOST=0.0.0.0
# PORT=8000
# LOG_LEVEL=info
